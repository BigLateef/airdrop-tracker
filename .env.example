# Neon Postgres connection string.
# Get it from your Neon project dashboard → Connection Details.
DATABASE_URL=postgres://user:password@ep-xxxx.neon.tech/dbname?sslmode=require

# Etherscan API key — powers the multichain V2 API (etherscan.io/apis, free tier is fine).
# Used for on-chain eligibility detection and sybil-signal lookups.
ETHERSCAN_API_KEY=

# Discord incoming webhook URL for the daily point update.
# Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL.
DISCORD_WEBHOOK_URL=

# Shared secret that cron-job.org must send to trigger a crawl.
# Generate any long random string, e.g. `openssl rand -hex 32`.
CRON_SECRET=
